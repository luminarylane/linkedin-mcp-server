# LinkedIn API Credentials
# Get your access token from https://developer.linkedin.com/apps

# OAuth 2.0 access token — required for all tools (expires after 60 days)
# Required scopes: openid, profile, w_member_social
LINKEDIN_ACCESS_TOKEN=your-access-token-here

# Optional: LinkedIn Organization ID (numeric, from your company page URL)
# Required only for org-level analytics tools (linkedin_get_org_analytics,
# linkedin_get_follower_stats, linkedin_get_mentions, linkedin_get_share_stats)
# LINKEDIN_ORG_ID=123456789
